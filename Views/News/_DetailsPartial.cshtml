                 $(document).on("click", ".react-btn", function () {
                     alert('f');
                     var commentId = $(this).data("comment");
                     var emoji = $(this).data("emoji");
                     $.post("/News/ReactToComment", { commentId, emoji }, function (data) {
                         let summaryText = data.map(r => `${r.emoji} ${r.count}`).join(" ");
                         $("#reaction-summary-" + commentId).text(summaryText);
                     }).fail(function () {
                         alert("Error reacting to comment.");
                     });
                 });


                $(document).off("click", ".recommend-btn")
                   .on("click", ".recommend-btn", function (e) {

            e.preventDefault();

            const btn = $(this);
            const newsId = btn.data("id");

            // prevent double click
            if (btn.data("loading")) return;
            btn.data("loading", true);

            $.ajax({
                url: "/News/Recommend",
                type: "POST",
                data: { newsId: newsId },
                success: function () {
                    btn.addClass("recommended")
                       .html("⭐ Recommended");

                    // Reload stories bar
                    $("#recommendedContainer").load("/News/Stories");
                },
                error: function (err) {
                    console.error(err);
                    alert("Unable to recommend");
                },
                complete: function () {
                    btn.data("loading", false);
                }
            });
        });


        
$(document).off("click", ".recommend-icon")
.on("click", ".recommend-icon", function () {

    const el = $(this);
    const id = el.data("id");

    // prevent double click
    if (el.hasClass("active")) return;

    // animation trigger
    el.addClass("animate");

    setTimeout(() => el.removeClass("animate"), 400);

    $.post("/News/Recommend", { newsId: id }, function () {

        el.addClass("active");

        // change icon to solid
        el.find("i")
          .removeClass("fa-regular")
          .addClass("fa-solid");

        // reload stories
        $("#recommendedContainer").load("/News/Stories");

    });
});
        /* SHARE */
        // function shareFB(id) {
        //     window.open("https://www.facebook.com/sharer/sharer.php?u=" + location.origin + "/News/Details/" + id);
        // }
        // function shareWA(id) {
        //     window.open("https://wa.me/?text=" + encodeURIComponent(location.origin + "/News/Details/" + id));
        // }
        // function shareTW(id) {
        //     window.open("https://twitter.com/intent/tweet?url=" + location.origin + "/News/Details/" + id);
        // }
        function getShareUrl(id){
        return window.location.origin + "/News/Details/" + id;
        }

        function increaseShareCount(id){
        $.post("/News/IncreaseShare", { id: id }, function(res){
        $("#shareCount").text(res.count);
        });
        }

        function shareFB(id){
        const url = getShareUrl(id);
        window.open(`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`);
        increaseShareCount(id);
        }

        function shareWA(id){
        const url = getShareUrl(id);
        window.open(`https://wa.me/?text=${encodeURIComponent(url)}`);
        increaseShareCount(id);
        }

        function shareTW(id){
        const url = getShareUrl(id);
        window.open(`https://twitter.com/intent/tweet?url=${encodeURIComponent(url)}`);
        increaseShareCount(id);
        }

        function copyLink(id){
        const url = getShareUrl(id);
        navigator.clipboard.writeText(url);

        alert("Link copied!");
        increaseShareCount(id);
        }


        function showSharedUsers(id){
        Fancybox.show([{
        src: "/News/GetSharedUsers?newsId=" + id,
        type: "ajax"
        }]);
        }

        function nativeShare(id){

        const url = window.location.origin + "/News/Details/" + id;

        if (navigator.share) {
        navigator.share({
        title: document.title,
        text: "Check this news",
        url: url
        }).then(() => {
        increaseShareCount(id);
        }).catch(err => console.log(err));
        } else {
        // fallback
        copyLink(id);
        }
        }
    </script>

