@model int // Parent Comment ID

<div class="reply-input-wrapper">
    <input type="hidden" class="parent-comment-id" value="@Model">

    <div class="reply-form">
        <input 
            type="text" 
            class="form-control reply-name-input" 
            placeholder="Your name"
            maxlength="100">

        <textarea 
            class="form-control reply-text-input" 
            placeholder="Write a reply..."
            rows="2"
            maxlength="1000"></textarea>

        <div class="reply-form-actions">
            <button class="btn btn-sm btn-primary btn-send-reply">Send</button>
            <button class="btn btn-sm btn-secondary btn-cancel-reply">Cancel</button>
        </div>
    </div>
</div>

<style>
    .reply-input-wrapper {
        background: #f9f9f9;
        border-radius: 6px;
        padding: 12px;
        border-left: 2px solid #0dcaf0;
    }

    .reply-form {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .reply-name-input,
    .reply-text-input {
        padding: 8px 12px;
        font-size: 0.9rem;
        border: 1px solid #dee2e6;
        border-radius: 4px;
        font-family: inherit;
    }

    .reply-name-input:focus,
    .reply-text-input:focus {
        outline: none;
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.15);
    }

    .reply-text-input {
        resize: vertical;
        min-height: 60px;
    }

    .reply-form-actions {
        display: flex;
        gap: 8px;
        justify-content: flex-end;
    }

    .btn-send-reply,
    .btn-cancel-reply {
        padding: 6px 16px;
        font-size: 0.85rem;
        font-weight: 500;
    }

    .btn-send-reply {
        background: #0d6efd;
        border: none;
        color: white;
    }

    .btn-send-reply:hover {
        background: #0b5ed7;
    }

    .btn-cancel-reply {
        background: #e9ecef;
        border: none;
        color: #212529;
    }

    .btn-cancel-reply:hover {
        background: #dee2e6;
    }

    @media (max-width: 768px) {
        .reply-input-wrapper {
            padding: 10px;
        }

        .reply-form-actions {
            flex-direction: column-reverse;
        }

        .btn-send-reply,
        .btn-cancel-reply {
            width: 100%;
        }
    }
</style>
