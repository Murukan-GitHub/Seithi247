    <!-- Floating Categories as Pills -->
    <div>


        <div class="news-categories-pills">
            @foreach (var category in Enum.GetValues(typeof(NewsCategory)).Cast<NewsCategory>())
            {
                @if (category.ToString() == "Home")
                {
                    <a href="/" class="pill pill-home active">
                        <i class="bi bi-house-fill"></i>
                        @category
                    </a>
                }
                else
                {
                    <a href="#" class="category-pill" data-category="@category">@category</a>
                }

            }
        </div>
