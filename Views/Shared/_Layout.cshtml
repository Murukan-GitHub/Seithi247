        /* Fade-in animation */
        .fade-in {
            animation: fadeInPopup 0.4s ease;
        }

        @@keyframes fadeInPopup {
            from {
                opacity: 0;
                transform: scale(0.95);
            }

            to {
                opacity: 1;
                transform: scale(1);
            }
        }

        /* Dark Mode background around content */
        .fancybox__backdrop {
            background: rgba(10, 10, 10, 0.92) !important;
        }

.add-comment{
    position:sticky;
    bottom:0;
    background: #333;
