}

/* recommended section */
.recommended-section{
    width:100%;
    padding:8px 10px;
    background:#000;
    margin-top:100px;
}


/* Header */
.recommended-header{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:8px;
    margin-top:10px;
}

/* Container */
.recommended-container{
    display:flex;
    gap:10px;
    overflow:hidden; /* important for auto scroll */
}

.recommended-container::-webkit-scrollbar{
    display:none;
}

/* Cards */
.recommended-card{
    min-width:160px;
    height:100px;
    border-radius:12px;
    overflow:hidden;
    transition:0.2s;
}

.recommended-card img{
    width:100%;
    height:100%;
    object-fit:cover;
}
.recommended-card:hover{
    transform:scale(1.05);
}
/* Overlay */
.rec-overlay{
    position:absolute;
    bottom:0;
    width:100%;
    padding:6px;
    background:rgba(0,0,0,0.6);
    color:#fff;
    font-size:12px;
}

/* Arrows */
.nav-arrows button{
    background:#111;
    border:none;
    color:#fff;
    width:30px;
    height:30px;
    border-radius:50%;
    margin-left:5px;
    cursor:pointer;
}

.nav-arrows button:hover{
    background:#ff004f;
}

.container{
    margin-top:250px 
}
.nav-arrows{
    display:flex;
}
.top-section{
    position:fixed;
    top:0;
    left:0;
    right:0;
    z-index:1000;
    background:#000;
    display:flex;
    flex-direction:column;
    z-index:1000;
}

/* Desktop pills */
.pills-container{
    display:flex;
    justify-content:center;
    gap:10px;
}
.menu-toggle,
.pills-drawer,
.drawer-overlay {
    display: none;
}
